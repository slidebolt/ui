{
  "compilerOptions": {
    "target": "es2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@repo/database": ["../../packages/database/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../packages/database" }
  ]
}
